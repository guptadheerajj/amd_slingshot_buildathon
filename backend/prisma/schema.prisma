generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String?
  streak    Int       @default(0)
  goalCalories Int    @default(2000)
  goalProtein  Int    @default(150)
  goalCarbs    Int    @default(250)
  goalFats     Int    @default(70)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  mealLogs  MealLog[]
}

model MealLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  imageUrl    String?
  items       String? // Stringified JSON array of items
  calories    Float    @default(0)
  protein     Float    @default(0)
  carbs       Float    @default(0)
  fats        Float    @default(0)
  sugar       Float    @default(0)
  timestamp   DateTime @default(now())
  
  // Predictive forecast outcome
  forecast    String?  // Sluggish, Stable Energy, etc.
}
